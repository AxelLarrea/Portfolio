---
import { socialLinks } from '../data/portfolio';
---

<footer class="container-frame pb-10 pt-4">
	<div class="footer-card flex flex-col items-start justify-between gap-4 rounded-[20px] border border-white/8 bg-black/18 px-5 py-5 md:flex-row md:items-center">
		<p class="font-mono text-[11px] uppercase tracking-[0.18em] text-(--text-soft)">
			© 2026 Axel Larrea
		</p>
		<div class="flex flex-wrap gap-4 text-sm text-(--text-muted)">
			{
				socialLinks.map((item) => (
					<a
						href={item.href}
						target={item.href.startsWith('http') ? '_blank' : undefined}
						rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
						class="focus-ring hover:text-(--text)"
					>
						{item.label}
					</a>
				))
			}
		</div>
	</div>
</footer>
