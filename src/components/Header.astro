---
import SunIcon from '../assets/icons/SunIcon.astro';
import MoonIcon from '../assets/icons/MoonIcon.astro';
import { sectionLinks } from '../data/portfolio';
---

<header class="sticky top-4 z-50 container-frame">
	<nav class="card rounded-xl flex items-center justify-between px-4 py-3 md:px-6">
		<a
			href="#inicio"
			data-section="#inicio"
			class="nav-logo font-display text-lg font-extrabold tracking-tight text-(--text) cursor-pointer transition-colors duration-300"
		>
			AL.DEV
		</a>

		<div class="hidden md:flex items-center gap-1">
			{
				sectionLinks.map((link) => (
					<a
						href={link.href}
						data-section={link.href}
						class="nav-link rounded-full px-3 py-1.5 text-sm text-(--text-muted) hover:text-(--text) hover:bg-(--surface-elevated) transition duration-200 cursor-pointer"
					>
						{link.label}
					</a>
				))
			}
		</div>

		<button
			id="theme-toggle"
			type="button"
			class="h-9 w-9 rounded-lg border border-(--border) bg-(--surface) hover:border-(--accent) cursor-pointer flex items-center justify-center transition-colors duration-200 focus-ring"
		>
			<SunIcon class="sun-icon w-5 h-5" />
			<MoonIcon class="moon-icon w-5 h-5" />
		</button>
	</nav>
</header>

<script>
	const themeToggle = document.getElementById('theme-toggle');
	const html = document.documentElement;
	const currentTheme = localStorage.getItem('portfolio-theme') || 'dark';
	html.classList.toggle('light', currentTheme === 'light');
	const sunIcon = document.querySelector('#theme-toggle .sun-icon');
	const moonIcon = document.querySelector('#theme-toggle .moon-icon');
	function updateIcons(isLight: boolean) {
		if (sunIcon && moonIcon) {
			sunIcon.classList.toggle('hidden', !isLight);
			moonIcon.classList.toggle('hidden', isLight);
		}
	}
	updateIcons(html.classList.contains('light'));
	themeToggle?.addEventListener('click', () => {
		const isLight = html.classList.toggle('light');
		localStorage.setItem('portfolio-theme', isLight ? 'light' : 'dark');
		updateIcons(isLight);
	});

	// ── Scroll-spy ──────────────────────────────
	const navItems = document.querySelectorAll<HTMLElement>('[data-section]');
	const sections = document.querySelectorAll<HTMLElement>('section[id]');

	let observerLocked = false;

	// Click manual: activar inmediatamente y congelar observer durante el scroll
	navItems.forEach((link) => {
		link.addEventListener('click', (e) => {
			navItems.forEach((l) => (l.dataset.active = 'false'));
			link.dataset.active = 'true';
			observerLocked = true;
			setTimeout(() => {
				observerLocked = false;
			}, 1000);

			// #inicio: forzar scroll al tope real de la página
			if (link.dataset.section === '#inicio') {
				e.preventDefault();
        window.location.hash = '#inicio';
				window.scrollTo({ top: 0, behavior: 'smooth' });
			}
		});
	});

	const observer = new IntersectionObserver((entries) => {
		if (observerLocked) return;

		const visible = entries
			.filter((e) => e.isIntersecting)
			.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

		if (visible.length > 0) {
			const currentId = `#${visible[0].target.id}`;
			navItems.forEach((link) => {
				link.dataset.active = link.dataset.section === currentId ? 'true' : 'false';
			});
		}
	}, {
		rootMargin: '-80px 0px -70% 0px',
		threshold: 0,
	});

	sections.forEach((section) => observer.observe(section));
</script>
