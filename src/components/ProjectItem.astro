---
import { Image } from 'astro:assets';

import GitRepoIcon from '../assets/icons/GitRepoIcon.astro';
import WebIcon from '../assets/icons/WebIcon.astro';
import type { ProjectItemData } from '../data/portfolio';

const { project } = Astro.props as { project: ProjectItemData };
---

<article
	class:list={[
		'glass-panel group overflow-hidden rounded-[24px] transition duration-500',
		project.accent === 'cyan' && 'hover:shadow-[0_0_32px_rgba(0,242,255,0.12)]',
		project.accent === 'violet' && 'hover:shadow-[0_0_32px_rgba(138,43,226,0.14)]'
	]}
>
	<div class="relative overflow-hidden">
		<Image
			src={project.image}
			alt={`Captura del proyecto ${project.title}`}
			width={960}
			height={600}
			format="webp"
			class="aspect-video w-full object-cover transition duration-700 group-hover:scale-[1.03]"
		/>
		<div class="absolute inset-0 bg-linear-to-t from-[rgba(255,255,255,0.9)] via-transparent to-transparent dark:from-[#131313]"></div>
	</div>

	<div class="border-t border-white/10 px-6 py-6 md:px-7">
		<div class="flex items-start justify-between gap-4">
			<h3 class="font-display text-2xl font-semibold tracking-[-0.03em] text-white">
				{project.title}
			</h3>
			<div class="flex items-center gap-2">
				<a
					href={project.liveUrl}
					target="_blank"
					rel="noreferrer"
					aria-label={`Abrir demo de ${project.title}`}
					class="focus-ring flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/3 transition duration-300 hover:border-[rgba(79,70,229,0.4)] hover:text-(--on-surface)"
				>
					<WebIcon class="h-4 w-4" />
				</a>
				<a
					href={project.codeUrl}
					target="_blank"
					rel="noreferrer"
					aria-label={`Abrir código de ${project.title}`}
					class="focus-ring flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/3 transition duration-300 hover:border-[rgba(113,42,226,0.4)] hover:text-(--on-surface)"
				>
					<GitRepoIcon class="h-4 w-4" />
				</a>
			</div>
		</div>

		<p class="mt-4 text-base leading-7 text-(--text-muted)">{project.description}</p>

		<div class="mt-6 flex flex-wrap gap-2">
			{
				project.stack.map((item) => (
					<span class="stack-pill rounded-[10px] border border-white/10 bg-white/4 px-3 py-2 font-mono text-[11px] uppercase tracking-[0.18em] text-(--text-muted)">
						{item}
					</span>
				))
			}
		</div>
	</div>
</article>
