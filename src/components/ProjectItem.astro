---
import { Image } from 'astro:assets';
import GitRepoIcon from '../assets/icons/GitRepoIcon.astro';
import WebIcon from '../assets/icons/WebIcon.astro';
import type { ProjectItemData } from '../data/portfolio';

const { project } = Astro.props as { project: ProjectItemData };
---

<article
	class:list={[
		'glass-surface project-card group overflow-hidden rounded-[24px] transition duration-500',
		project.accent === 'cyan' && 'project-card-cyan',
		project.accent === 'violet' && 'project-card-violet'
	]}
>
	<div class="relative overflow-hidden">
		<Image
			src={project.image}
			alt={`Captura del proyecto ${project.title}`}
			width={960}
			height={600}
			format="webp"
			loading="lazy"
			decoding="async"
			class="aspect-video w-full object-cover transition duration-700 group-hover:scale-[1.03]"
		/>
		<div class="absolute inset-0 bg-linear-to-t from-black/90 via-transparent to-transparent"></div>
	</div>

	<div class="border-t border-(--border) px-6 py-6 md:px-7">
		<div class="flex items-start justify-between gap-4">
			<h3 class="font-display text-2xl font-semibold tracking-[-0.03em] text-(--text)">
				{project.title}
			</h3>
			<div class="flex gap-2">
				<a
					href={project.liveUrl}
					target="_blank"
					rel="noreferrer"
					aria-label={`Abrir demo de ${project.title}`}
					class="focus-ring flex h-11 w-11 items-center justify-center rounded-full border border-(--border) bg-white/3 transition duration-300 hover:border-(--primary)/40 hover:text-(--text)"
				>
					<WebIcon class="h-4 w-4" />
				</a>
				<a
					href={project.codeUrl}
					target="_blank"
					rel="noreferrer"
					aria-label={`Abrir código de ${project.title}`}
					class="focus-ring flex h-11 w-11 items-center justify-center rounded-full border border-(--border) bg-white/3 transition duration-300 hover:border-(--secondary)/40 hover:text-(--text)"
				>
					<GitRepoIcon class="h-4 w-4" />
				</a>
			</div>
		</div>

		<p class="mt-4 text-base leading-7 text-(--text-muted)">{project.description}</p>

		<div class="mt-6 flex flex-wrap gap-2">
			{project.stack.map((item) => (
				<span class="stack-pill">{item}</span>
			))}
		</div>
	</div>
</article>
