---
import { Image } from 'astro:assets';
import type { ProjectItemData } from '../data/portfolio';
import GitRepoIcon from '../assets/icons/GitRepoIcon.astro';
import WebIcon from '../assets/icons/WebIcon.astro';

const { project } = Astro.props as { project: ProjectItemData };
---

<article class="card-interactive card rounded-xl overflow-hidden group">
	<div class="relative overflow-hidden">
		<Image
			src={project.image}
			alt={project.title}
			class="aspect-video w-full object-cover transition duration-700 group-hover:scale-105"
		/>
		<div
			class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
			style="background: linear-gradient(to top, var(--base), transparent);"
		>
		</div>
	</div>

	<div class="p-5 md:p-6">
		<div class="flex justify-between items-start gap-3">
			<h3 class="font-display text-xl font-semibold tracking-[-0.02em] text-(--text)">
				{project.title}
			</h3>

			<div class="flex gap-2">
				<a
					href={project.liveUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="h-10 w-10 rounded-lg flex items-center justify-center cursor-pointer focus-ring transition-colors duration-200"
					style="border: 1px solid var(--border); background: var(--surface); color: var(--text-muted);"
					onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)';"
					onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)';"
				>
					<WebIcon class="h-4 w-4" />
				</a>

				<a
					href={project.codeUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="h-10 w-10 rounded-lg flex items-center justify-center cursor-pointer focus-ring transition-colors duration-200"
					style="border: 1px solid var(--border); background: var(--surface); color: var(--text-muted);"
					onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)';"
					onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)';"
				>
					<GitRepoIcon class="h-4 w-4" />
				</a>
			</div>
		</div>

		<p class="mt-3 text-sm leading-6 text-muted">{project.description}</p>

		<div class="mt-4 flex flex-wrap gap-2">
			{project.stack.map((tech) => (
				<span class="tag">{tech}</span>
			))}
		</div>
	</div>
</article>
