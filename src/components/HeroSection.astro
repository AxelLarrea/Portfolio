---
import { Image } from 'astro:assets';
import GithubIcon from '../assets/icons/GithubIcon.astro';
import LinkedInIcon from '../assets/icons/LinkedInIcon.astro';
import GmailIcon from '../assets/icons/GmailIcon.astro';
import { cv, heroHighlights, profile, socialLinks } from '../data/portfolio';

const socialIcons = {
	linkedin: LinkedInIcon,
	github: GithubIcon,
	email: GmailIcon,
};
---

<section id="inicio" class="card relative rounded-2xl p-8 md:p-12 text-center overflow-hidden">
	<div class="absolute top-0 inset-x-0 h-0.5 bg-(--accent)/40"></div>

	<div class="relative mb-8 inline-block">
		<div
			class="absolute inset-[-12px] rounded-full blur-lg"
			style="background: radial-gradient(circle, var(--accent) 0%, transparent 70%); opacity: 0.18;"
		></div>
		<div class="relative rounded-full border-2 border-(--accent)/50 p-[3px]">
			<Image
				src={profile.image}
				alt={profile.name}
				class="h-40 w-40 md:h-48 md:w-48 rounded-full border-2 border-(--base) object-cover"
			/>
		</div>
		<span class="absolute bottom-3 right-3 h-3.5 w-3.5 rounded-full bg-(--accent) ring-2 ring-(--base)"></span>
	</div>

	<p class="section-kicker mb-4">{profile.kicker}</p>

	<h1 class="font-display text-4xl md:text-6xl font-extrabold leading-[1.08]" style="letter-spacing: -0.04em;">
		<span class="text-(--text)">{profile.name}</span>
		<br />
		<span class="text-(--accent)">{profile.headline}</span>
	</h1>

	<p class="mt-5 max-w-2xl mx-auto text-base md:text-lg leading-7 text-(--text-muted)">
		{profile.intro}
	</p>

	<div class="mt-8 flex flex-wrap justify-center gap-3">
		{
			socialLinks.map((link) => {
				const Icon = socialIcons[link.icon];
				return (
					<a
						href={link.href}
						class="social-link cursor-pointer"
						target="_blank"
						rel="noopener noreferrer"
					>
						<span class="flex items-center justify-center h-8 w-8 rounded-full bg-(--base)">
							<Icon class="w-4 h-4" />
						</span>
						<span class="text-sm font-medium">{link.label}</span>
					</a>
				);
			})
		}
	</div>

	<a
		href={cv.href}
		download={cv.downloadName}
		class="btn-primary cursor-pointer mt-8 mx-auto inline-flex"
	>
		Descargar CV
	</a>

	<div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
		{
			heroHighlights.map((item, i) => (
				<div class="card text-left p-4">
					<span class="font-mono text-xs font-medium text-(--accent)">
						{String(i + 1).padStart(2, '0')}
					</span>
					<p class="mt-2 text-sm text-(--text-muted)">{item}</p>
				</div>
			))
		}
	</div>
</section>
