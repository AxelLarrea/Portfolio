---
import { Image } from 'astro:assets';

import GithubIcon from '../assets/icons/GithubIcon.astro';
import LinkedInIcon from '../assets/icons/LinkedInIcon.astro';
import GmailIcon from '../assets/icons/GmailIcon.astro';
import { cv, heroHighlights, profile, socialLinks } from '../data/portfolio';

const socialIcons = {
	linkedin: LinkedInIcon,
	github: GithubIcon,
	email: GmailIcon
};
---

<section
	id="inicio"
	class="glass-panel relative overflow-hidden rounded-[28px] border border-(--border) px-6 py-10 md:px-10 md:py-16"
>
	<div class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-(--primary-dim) to-transparent"></div>
	<div class="absolute inset-y-0 left-0 w-px bg-linear-to-b from-transparent via-white/10 to-transparent"></div>
	<div class="absolute inset-y-0 right-0 w-px bg-linear-to-b from-transparent via-white/10 to-transparent"></div>

	<div class="mx-auto flex max-w-4xl flex-col items-center text-center">
		<div class="relative mb-8">
			<div
				class="absolute inset-[-18px] rounded-[26px] blur-xl"
				style="background: radial-gradient(circle, color-mix(in srgb, var(--primary) 20%, transparent), transparent 72%)"
			></div>
			<div class="relative rounded-[26px] border border-(--primary)/45 bg-linear-to-b from-(--primary)/14 to-(--secondary)/12 p-[6px] shadow-[0_0_32px_var(--primary-glow)]">
				<Image
					src={profile.image}
					alt={`Foto de perfil de ${profile.name}`}
					width={220}
					height={220}
					format="webp"
					fetchpriority="high"
					class="h-[180px] w-[180px] rounded-[22px] border border-white/10 object-cover md:h-[220px] md:w-[220px]"
				/>
			</div>
			<div class="absolute bottom-3 right-3 h-4 w-4 rounded-full border-2 border-(--base) bg-(--success) shadow-[0_0_14px_var(--success)]"></div>
		</div>

		<p class="section-kicker mb-4">{profile.kicker}</p>
		<h1 class="font-display max-w-4xl text-4xl font-extrabold leading-[1.05] tracking-[-0.04em] text-(--text) md:text-6xl">
			Hola, soy {profile.name}.
			<span class="block text-(--primary)">
				{profile.headline}
			</span>
		</h1>
		<p class="mt-5 max-w-2xl text-base leading-7 text-(--text-muted) md:text-lg">{profile.intro}</p>

		<div class="mt-8 flex w-full flex-wrap justify-center gap-3">
			{
				socialLinks.map((item) => {
					const Icon = socialIcons[item.icon];

					return (
						<a
							href={item.href}
							target={item.href.startsWith('http') ? '_blank' : undefined}
							rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
							class:list={[
								'social-link focus-ring group flex w-full items-center gap-3 rounded-[14px] border px-4 py-3 transition duration-300 sm:w-auto',
								item.accent === 'cyan' && 'social-link-cyan',
								item.accent === 'violet' && 'social-link-violet',
								item.accent === 'neutral' && 'social-link-neutral'
							]}
						>
							<div class="flex h-9 w-9 items-center justify-center rounded-full bg-black/20">
								<Icon class="h-4 w-4" />
							</div>
							<div class="text-left">
								<p class="font-mono text-[11px] uppercase tracking-[0.22em] text-(--text-soft)">{item.description}</p>
								<p class="text-sm font-medium text-(--text)">{item.label}</p>
							</div>
						</a>
					);
				})
			}
		</div>

		<a
			href={cv.href}
			download={cv.downloadName}
			class="cv-button focus-ring mt-8 px-5 py-3 text-sm"
		>
			Descargar CV
		</a>

		<div class="mt-10 grid w-full grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-3">
			{
				heroHighlights.map((item, index) => (
					<div class="hero-highlight text-left">
						<p class="font-mono text-[11px] uppercase tracking-[0.28em] text-(--text-soft)">
							0{index + 1}
						</p>
						<p class="mt-3 text-sm leading-6 text-(--text-muted)">{item}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
