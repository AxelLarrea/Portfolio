---
import CssIcon from '../assets/icons/technologies/CSSIcon.astro';
import ReactIcon from '../assets/icons/technologies/ReactIcon.astro';
import TailwindIcon from '../assets/icons/technologies/TailwindIcon.astro';
import TypescriptIcon from '../assets/icons/technologies/TypescriptIcon.astro';
import SupabaseIcon from '../assets/icons/technologies/SupabaseIcon.astro';
import HtmlIcon from '../assets/icons/technologies/HTMLIcon.astro';
import JavascriptIcon from '../assets/icons/technologies/JavascriptIcon.astro';
import NodeIcon from '../assets/icons/technologies/NodeIcon.astro';
import { technologies } from '../data/portfolio';

const technologyIcons = {
	html: HtmlIcon,
	css: CssIcon,
	javascript: JavascriptIcon,
	typescript: TypescriptIcon,
	react: ReactIcon,
	node: NodeIcon,
	tailwind: TailwindIcon,
	supabase: SupabaseIcon
};

const featured = new Set(['React', 'TypeScript', 'Tailwind CSS']);
const featuredTechs = technologies.filter((t) => featured.has(t.name));
const otherTechs = technologies.filter((t) => !featured.has(t.name));
---

<section id="tecnologias">
	<div class="mb-8">
		<h2 class="font-display text-3xl font-bold tracking-[-0.04em] text-(--text) md:text-4xl">
			Stack técnico para interfaces, servicios y producto web.
		</h2>
	</div>

	<!-- Featured row: larger cards with prominent icons -->
	<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
		{
			featuredTechs.map((tech) => {
				const Icon = tech.icon ? technologyIcons[tech.icon] : undefined;

				return (
					<div
						class:list={[
							'stagger-1 glass-surface group rounded-[24px] px-6 py-7 transition-[transform_border-color] duration-300 ease-out hover:-translate-y-1',
							tech.accent === 'cyan' && 'hover:border-[rgba(0,242,255,0.22)]',
							tech.accent === 'violet' && 'hover:border-[rgba(138,43,226,0.24)]',
							tech.accent === 'neutral' && 'hover:border-white/15'
						]}
					>
						<div class="flex items-start gap-5">
							<div
								class:list={[
									'flex h-16 w-16 shrink-0 items-center justify-center rounded-[18px]',
									tech.accent === 'cyan' && 'border border-[rgba(0,242,255,0.3)] bg-[rgba(0,242,255,0.08)]',
									tech.accent === 'violet' && 'border border-[rgba(138,43,226,0.3)] bg-[rgba(138,43,226,0.08)]',
									tech.accent === 'neutral' && 'border border-white/10 bg-black/20'
								]}
							>
								{
									Icon ? (
										<Icon class="h-9 w-9" />
									) : (
										<span class="font-mono text-lg font-semibold tracking-[0.2em] text-(--on-primary-container)">
											{tech.badge}
										</span>
									)
								}
							</div>
							<div class="min-w-0">
								<h3 class="font-display text-xl font-semibold tracking-[-0.03em] text-(--text)">{tech.name}</h3>
								<p class="mt-2 text-sm leading-6 text-(--text-soft)">{tech.detail}</p>
							</div>
						</div>
					</div>
				);
			})
		}
	</div>

	<!-- Compact row: border-only chips, horizontal layout -->
	<div class="mt-5 flex flex-wrap gap-3">
		{
			otherTechs.map((tech, index) => {
				const Icon = tech.icon ? technologyIcons[tech.icon] : undefined;

				return (
					<div
						class:list={[
							`stagger-${index + 2}`,
							'secondary-pill group flex items-center gap-2.5 rounded-xl border border-(--surface-border) bg-linear-to-b from-white/[0.045] to-white/[0.025] px-4 py-2.5 transition duration-300 ease-out hover:border-(--outline)'
						]}
					>
						{
							Icon ? (
								<Icon class="h-5 w-5 shrink-0" />
							) : (
								<span class="font-mono text-xs font-semibold tracking-[0.2em] text-(--on-primary-container)">
									{tech.badge}
								</span>
							)
						}
						<span class="font-medium text-sm text-(--text-muted)">{tech.name}</span>
					</div>
				);
			})
		}
	</div>
</section>
