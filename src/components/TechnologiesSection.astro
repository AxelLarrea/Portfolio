---
import CssIcon from '../assets/icons/technologies/CSSIcon.astro';
import ReactIcon from '../assets/icons/technologies/ReactIcon.astro';
import TailwindIcon from '../assets/icons/technologies/TailwindIcon.astro';
import TypescriptIcon from '../assets/icons/technologies/TypescriptIcon.astro';
import SupabaseIcon from '../assets/icons/technologies/SupabaseIcon.astro';
import HtmlIcon from '../assets/icons/technologies/HTMLIcon.astro';
import JavascriptIcon from '../assets/icons/technologies/JavascriptIcon.astro';
import NodeIcon from '../assets/icons/technologies/NodeIcon.astro';
import { technologies } from '../data/portfolio';

const technologyIcons = {
	html: HtmlIcon,
	css: CssIcon,
	javascript: JavascriptIcon,
	typescript: TypescriptIcon,
	react: ReactIcon,
	node: NodeIcon,
	tailwind: TailwindIcon,
	supabase: SupabaseIcon
};
---

<section id="tecnologias">
	<div class="mb-6">
		<p class="section-kicker">03 / Tecnologías</p>
		<h2 class="font-display mt-3 text-3xl font-bold tracking-[-0.04em] text-white md:text-4xl">
			Stack técnico para interfaces, servicios y producto web.
		</h2>
	</div>

	<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
		{
			technologies.map((tech) => {
				const Icon = tech.icon ? technologyIcons[tech.icon] : undefined;

				return (
					<div
						class:list={[
							'glass-panel group rounded-[20px] px-5 py-5 transition duration-300 hover:-translate-y-1',
							tech.accent === 'cyan' && 'hover:border-[rgba(0,242,255,0.22)]',
							tech.accent === 'violet' && 'hover:border-[rgba(138,43,226,0.24)]',
							tech.accent === 'neutral' && 'hover:border-white/15'
						]}
					>
						<div class="flex items-center gap-4">
							<div class="flex h-14 w-14 items-center justify-center rounded-[16px] border border-white/10 bg-black/20">
								{
									Icon ? (
										<Icon class="h-8 w-8" />
									) : (
										<span class="font-mono text-lg font-semibold tracking-[0.2em] text-[#e1fdff]">
											{tech.badge}
										</span>
									)
								}
							</div>
							<div>
								<h3 class="font-display text-xl font-semibold tracking-[-0.03em] text-white">{tech.name}</h3>
								<p class="mt-1 text-sm leading-6 text-(--text-soft)">{tech.detail}</p>
							</div>
						</div>
					</div>
				);
			})
		}
	</div>
</section>
