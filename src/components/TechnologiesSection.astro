---
import HtmlIcon from '../assets/icons/technologies/HTMLIcon.astro';
import CssIcon from '../assets/icons/technologies/CSSIcon.astro';
import JavascriptIcon from '../assets/icons/technologies/JavascriptIcon.astro';
import TypescriptIcon from '../assets/icons/technologies/TypescriptIcon.astro';
import ReactIcon from '../assets/icons/technologies/ReactIcon.astro';
import NodeIcon from '../assets/icons/technologies/NodeIcon.astro';
import TailwindIcon from '../assets/icons/technologies/TailwindIcon.astro';
import SupabaseIcon from '../assets/icons/technologies/SupabaseIcon.astro';
import TanStackQueryIcon from '../assets/icons/technologies/TanStackQueryIcon.astro';
import ZustandIcon from '../assets/icons/technologies/ZustandIcon.astro';
import ReactRouterIcon from '../assets/icons/technologies/ReactRouterIcon.astro';
import { technologies } from '../data/portfolio';

const iconMap = {
	html: HtmlIcon,
	css: CssIcon,
	javascript: JavascriptIcon,
	typescript: TypescriptIcon,
	react: ReactIcon,
	node: NodeIcon,
	tailwind: TailwindIcon,
	supabase: SupabaseIcon,
	reactRouter: ReactRouterIcon,
	tanstackQuery: TanStackQueryIcon,
	zustand: ZustandIcon,
};

const featuredOrder = ['React', 'TypeScript', 'Tailwind CSS'];
const featured = featuredOrder
	.map((name) => technologies.find((t) => t.name === name)!)
	.filter(Boolean);
const secondary = technologies.filter((t) => !featuredOrder.includes(t.name));
---

<section id="tecnologias">
	<div class="w-12 h-1 bg-(--accent) rounded-full mb-5"></div>
	<h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-(--text) mb-6 md:text-3xl">
		Tecnologías
	</h2>

	<div class="grid grid-cols-2 gap-4 lg:grid-cols-3">
		{
			featured.map((tech, i) => {
				const Icon = tech.icon ? iconMap[tech.icon] : null;
				return (
					<div class={`stagger-${i + 1} h-full`}>
						<div class="card p-5 flex items-start gap-4 h-full hover:-translate-y-1 hover:border-(--accent) cursor-pointer">
							<div class="h-14 w-14 rounded-xl bg-(--accent-soft) border border-(--accent)/30 flex items-center justify-center shrink-0">
								{Icon && <Icon class="h-8 w-8" />}
							</div>
							<div class="min-w-0">
								<h3 class="font-display text-lg font-semibold text-(--text)">{tech.name}</h3>
								<p class="text-sm text-(--text-muted) mt-1">{tech.detail}</p>
							</div>
						</div>
					</div>
				);
			})
		}
	</div>
  
	<div class="mt-4 flex flex-wrap gap-2">
		{
			secondary.map((tech) => {
				const Icon = tech.icon ? iconMap[tech.icon] : null;
				return (
					<span class="tag flex items-center gap-2 px-3 py-2 cursor-pointer">
						{tech.badge
							? <span class="font-mono text-[10px]">{tech.badge}</span>
							: Icon && <Icon class="h-4 w-4" />
						}
						{tech.name}
					</span>
				);
			})
		}
	</div>
</section>
