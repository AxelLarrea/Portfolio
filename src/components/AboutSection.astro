---
import { aboutContent } from '../data/portfolio';
---

<section id="sobre-mi" class="grid grid-cols-1 md:grid-cols-[1fr_1.6fr] gap-6">
	<div class="card p-6 md:p-8">
		<div class="w-12 h-1 bg-(--accent) rounded-full mb-5"></div>
		<h2 class="font-display text-2xl md:text-3xl font-bold text-(--text)" style="letter-spacing: -0.03em;">
			{aboutContent.title}
		</h2>
		<p class="mt-4 text-lg leading-7 text-(--text-muted)">
			{aboutContent.lead}
		</p>
	</div>

	<div class="card p-6 md:p-8">
		{
			aboutContent.paragraphs.map((paragraph) => (
				<p class="text-base leading-7 text-(--text-muted) mt-4 first:mt-0">
					{paragraph}
				</p>
			))
		}

		<div class="mt-6 flex flex-wrap gap-2">
			{
				aboutContent.pills.map((pill, i) => (
					<span
						class={`tag cursor-pointer ${
							i === 0
								? 'border-(--accent) text-(--accent) bg-(--accent-soft)'
								: ''
						}`}
					>
						{pill}
					</span>
				))
			}
		</div>
	</div>
</section>
