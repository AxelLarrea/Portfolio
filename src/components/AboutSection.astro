---
import { aboutContent } from '../data/portfolio';
---

<section id="sobre-mi" class="">
  <div class="w-12 h-1 bg-(--accent) rounded-full mb-5"></div>
  <h2 class="font-display text-2xl md:text-3xl font-bold mb-6 text-(--text)" style="letter-spacing: -0.03em;">
    {aboutContent.title}
  </h2>
	<div class="card p-6 md:p-8">
    {
      aboutContent.paragraphs.map((paragraph) => (
        <p class="text-base leading-7 text-(--text-muted) first:mt-0">
          {paragraph}
        </p>
      ))
    }
	</div>
</section>
