---
import { aboutContent } from '../data/portfolio';
---

<section id="sobre-mi" class="grid gap-6 md:grid-cols-[0.95fr_1.65fr]">
	<div class="glass-panel rounded-[24px] px-6 py-7 md:px-8 md:py-10">
		<p class="section-kicker">01 / Sobre mí</p>
		<h2 class="font-display mt-4 text-3xl font-bold tracking-[-0.04em] text-white md:text-4xl">
			{aboutContent.title}
		</h2>
		<p class="mt-4 text-sm leading-7 text-(--text-muted)">{aboutContent.lead}</p>
	</div>

	<div class="glass-panel rounded-[24px] px-6 py-7 md:px-8 md:py-10">
		{
			aboutContent.paragraphs.map((paragraph, index) => (
				<p class:list={['text-lg leading-8 text-(--text-muted)', index > 0 && 'mt-5']}>{paragraph}</p>
			))
		}
		<div class="mt-6 flex flex-wrap gap-3">
			{
				aboutContent.pills.map((pill, index) => (
					<span
						class:list={[
							'rounded-full px-4 py-2 font-mono text-xs uppercase tracking-[0.18em]',
							index === 0
								? 'about-pill-cyan'
								: 'about-pill-neutral'
						]}
					>
						{pill}
					</span>
				))
			}
		</div>
	</div>
</section>
