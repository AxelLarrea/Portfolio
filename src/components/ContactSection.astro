---
import CopyIcon from '../assets/icons/CopyIcon.astro';
import SendIcon from '../assets/icons/SendIcon.astro';
import GithubIcon from '../assets/icons/GithubIcon.astro';
import LinkedInIcon from '../assets/icons/LinkedInIcon.astro';
import GmailIcon from '../assets/icons/GmailIcon.astro';
import { cv, socialLinks } from '../data/portfolio';

const socialIconMap: Record<string, typeof GithubIcon> = {
	linkedin: LinkedInIcon,
	github: GithubIcon,
	email: GmailIcon,
};
---

<section id="contacto">
	<div class="w-12 h-1 bg-(--accent) rounded-full mb-5"></div>

	<h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-(--text) md:text-3xl">
		Contacto
	</h2>

	<p class="mt-3 text-base leading-7 text-(--text-muted)">
		Actualmente estoy explorando nuevas oportunidades como Frontend Developer.
	</p>
  <p class="mt-1 text-base leading-7 text-(--text-muted)">
    Si te interesa conversar sobre una posición o proyecto, podés escribirme por correo electrónico.
	</p>

	<div class="card rounded-xl p-6 mt-6">
		<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
			<span class="font-mono text-sm text-(--text) truncate">axel.larrea.9@gmail.com</span>

			<div class="flex gap-2">
				<button id="copy-email" class="btn-secondary cursor-pointer">
					<CopyIcon class="h-4 w-4" />
					<span>Copiar</span>
				</button>
				<a href="mailto:axel.larrea.9@gmail.com" class="btn-secondary cursor-pointer">
					<SendIcon class="h-4 w-4" />
					<span>Enviar</span>
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	const btn = document.getElementById('copy-email');
	btn?.addEventListener('click', async () => {
		try {
			await navigator.clipboard.writeText('axel.larrea.9@gmail.com');
			btn.dataset.copied = 'true';
			const span = btn.querySelector('span');
			if (span) span.textContent = 'Copiado';
			const reset = (e: MouseEvent) => {
				if (!btn.contains(e.target as Node)) {
					delete btn.dataset.copied;
					if (span) span.textContent = 'Copiar';
					document.removeEventListener('click', reset);
				}
			};
			setTimeout(() => document.addEventListener('click', reset), 100);
		} catch {}
	});
</script>
