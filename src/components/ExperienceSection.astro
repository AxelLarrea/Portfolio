---
import { experience } from '../data/portfolio';

const exp = experience[0];
---

<section id="experiencia">
	<div class="w-12 h-1 bg-(--accent) rounded-full mb-5"></div>
	<h2 class="font-display text-2xl md:text-3xl font-bold tracking-[-0.03em] mb-6 text-(--text)">
		Experiencia
	</h2>

	<div class="stagger-1">
		<article class="card rounded-xl overflow-hidden border-l-[3px] border-l-(--accent)">
			<div class="p-6 md:p-8">
				<span class="font-mono text-xs text-(--accent) uppercase tracking-wider">
					{exp.period}
				</span>

				<h3 class="font-display text-2xl font-bold tracking-[-0.03em] text-(--text) mt-1">
					{exp.company}
				</h3>

				<p class="text-base text-muted">{exp.role}</p>

				<ul class="mt-5 space-y-3">
					{exp.description.map((item) => (
						<li class="flex items-center gap-3 text-sm leading-6 text-muted">
							<span class="h-1.5 w-1.5 rounded-full bg-(--accent) shrink-0"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>

				<p class="mt-4 text-base text-muted">Stack:  </p>
        <div class="flex flex-wrap gap-2">
          {exp.stack.map((tech) => (
            <span class="tag">{tech}</span>
          ))}
        </div>
			</div>
		</article>
	</div>
</section>
