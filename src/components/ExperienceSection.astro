---
import { experience } from '../data/portfolio';

const exp = experience[0];
---

<section id="experiencia" class="container-frame py-16 md:py-24">
	<h2 class="font-display text-2xl font-bold tracking-[-0.03em] mb-6 text-(--accent)">
		Experiencia
	</h2>

	<div class="stagger-1">
		<article class="card rounded-xl overflow-hidden border-l-[3px] border-l-(--accent)">
			<div class="p-6 md:p-8">
				<span class="font-mono text-xs text-(--accent) uppercase tracking-wider">
					{exp.period}
				</span>

				<h3 class="font-display text-2xl font-bold tracking-[-0.03em] text-(--text) mt-1">
					{exp.company}
				</h3>

				<p class="text-base text-muted">{exp.role}</p>

				<ul class="mt-5 space-y-3">
					{exp.description.map((item) => (
						<li class="flex gap-3 text-sm leading-6 text-muted">
							<span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-(--accent) shrink-0"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>
		</article>
	</div>
</section>
