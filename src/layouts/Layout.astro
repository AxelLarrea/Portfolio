---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Axel Larrea | Desarrollador Web',
	description = 'Portfolio personal de Axel Larrea con foco en desarrollo web, proyectos y stack técnico.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&family=Sora:wght@600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/porftolio.svg" />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<slot />
		</div>
	</body>
</html>
