---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Axel Larrea | Desarrollador Web',
	description = 'Portfolio personal de Axel Larrea — desarrollo web, interfaces modernas y código limpio.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#F8FAFC" media="(prefers-color-scheme: light)" />
		<!-- JetBrains Mono for code, Space Grotesk for hero accent — Onest Variable loaded via Fontsource -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/porftolio.svg" />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<slot />
		</div>

		<script>
			history.scrollRestoration = 'manual';

			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach(e => e.target.classList.toggle('is-visible', e.isIntersecting));
				},
				{ threshold: 0.12 }
			);

			document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
			addEventListener('beforeunload', () => observer.disconnect());

			const sections = ['#inicio', '#sobre-mi', '#experiencia', '#proyectos', '#tecnologias', '#contacto'];
			addEventListener('keydown', (e) => {
				if ((e.ctrlKey || e.metaKey) && e.key >= '1' && e.key <= '6') {
					e.preventDefault();
					const t = document.querySelector(sections[+e.key - 1]);
					if (t) t.scrollIntoView({ behavior: 'smooth' });
				}
			});

			addEventListener('load', () => window.scrollTo(0, 0));
		</script>
	</body>
</html>
