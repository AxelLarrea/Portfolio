---
import AboutSection from '../components/AboutSection.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import TechnologiesSection from '../components/TechnologiesSection.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Axel Larrea | Portfolio"
	description="Portfolio personal de Axel Larrea, desarrollador web enfocado en interfaces modernas, código limpio y productos web de alta calidad."
>
	<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
		<div class="absolute left-[-10rem] top-[-8rem] h-[24rem] w-[24rem] rounded-full bg-[radial-gradient(circle,rgba(0,242,255,0.18),transparent_68%)] blur-2xl"></div>
		<div class="absolute bottom-[-10rem] right-[-8rem] h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle,rgba(138,43,226,0.16),transparent_70%)] blur-2xl"></div>
	</div>

	<Header />

	<main class="container-frame pb-16 pt-8 md:pt-10">
		<HeroSection />

		<div class="scanner-line my-10 md:my-14"></div>

		<AboutSection />

		<div class="scanner-line my-10 md:my-14"></div>

		<ProjectsSection />

		<div class="scanner-line my-10 md:my-14"></div>

		<TechnologiesSection />
	</main>

	<Footer />
</Layout>
